# Environment variables for development
PORT=3000

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=obsidian_panel

# Gateway Configuration
WORKER_REQ_ENDPOINT=tcp://localhost:5555
WORKER_PUSH_ENDPOINT=tcp://localhost:5556
WORKER_SUB_ENDPOINT=tcp://localhost:5557

# Worker Configuration
REQ_BIND_ADDR=tcp://0.0.0.0:5555
PULL_BIND_ADDR=tcp://0.0.0.0:5556
PUB_BIND_ADDR=tcp://0.0.0.0:5557

# Logging
RUST_LOG=info,gateway=debug,worker=debug
