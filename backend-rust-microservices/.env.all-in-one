# Environment variables for all-in-one deployment
# Update these with your external MongoDB details

# External MongoDB (your hosted instance)
MONGO_URI=mongodb://your-mongo-host:27017
# Example for MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net
# Example for Railway/Render:
# MONGO_URI=mongodb://user:pass@containers-us-west-123.railway.app:6543

MONGO_DB_NAME=obsidian_panel

# Logging level
RUST_LOG=info,gateway=debug,worker=debug
