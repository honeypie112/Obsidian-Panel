# All-in-One Microservices Deployment
# Frontend + Gateway + Worker in ONE container

# Your external MongoDB connection
MONGO_URI=mongodb://your-mongo-host:27017
# Examples:
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net
# Railway: mongodb://user:pass@containers-us-west-123.railway.app:6543
# Local MongoDB accessed from container: mongodb://host.docker.internal:27017

MONGO_DB_NAME=obsidian_panel

# Logging (optional)
RUST_LOG=info,gateway=debug,worker=debug
